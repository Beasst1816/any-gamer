<?xml version="1.0" encoding="UTF-8"?>
<resources>
    <!-- Generic USB serial device filtering for usb_serial plugin -->
    <!-- This allows detection of common USB-to-serial adapters and microcontrollers -->

    <!-- Arduino (VID: 0x2341) -->
    <usb-device vendor-id="0x2341" product-id="0x0043" />
    <usb-device vendor-id="0x2341" product-id="0x0001" />

    <!-- CH340 (VID: 0x1A86) -->
    <usb-device vendor-id="0x1a86" product-id="0x7523" />

    <!-- FTDI (VID: 0x0403) -->
    <usb-device vendor-id="0x0403" product-id="0x6001" />
    <usb-device vendor-id="0x0403" product-id="0x6010" />
    <usb-device vendor-id="0x0403" product-id="0x6011" />
    <usb-device vendor-id="0x0403" product-id="0x6014" />
    <usb-device vendor-id="0x0403" product-id="0x6015" />

    <!-- Silicon Labs CP210x (VID: 0x10C4) -->
    <usb-device vendor-id="0x10c4" product-id="0xea60" />
    <usb-device vendor-id="0x10c4" product-id="0xea70" />

    <!-- Prolific PL2303 (VID: 0x067B) -->
    <usb-device vendor-id="0x067b" product-id="0x2303" />

    <!-- Add custom VID/PID pairs for your specific device:
         Replace 0xXXXX with your actual vendor ID and product ID
         You can find these by running 'adb logcat' while connecting your device
    <usb-device vendor-id="0xXXXX" product-id="0xXXXX" />
    -->
</resources>

